{
  "name": "rn-light-scanner",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:17pro": "expo run:ios --simulator \"iPhone 17 Pro\"",
    "ios:device": "expo run:ios --device",
    "ios:clean": "expo run:ios --clear-cache",
    "clean:all": "watchman watch-del-all && rm -rf node_modules && npm install",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@expo/ui": "~56.0.14",
    "expo": "~56.0.5",
    "expo-constants": "~56.0.15",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.12",
    "expo-media-library": "~56.0.6",
    "expo-router": "~56.2.7",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-document-scanner-plugin": "^2.0.4",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/react": "~19.2.2",
    "cspell": "^10.0.0",
    "typescript": "~6.0.3"
  }
}
